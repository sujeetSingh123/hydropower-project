NODE_ENV=development
PORT=5000

# Database
DATABASE_URL=postgresql://hydro_user:hydro_secret_2024@localhost:5432/hydropower
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=hydropower
POSTGRES_USER=hydro_user
POSTGRES_PASSWORD=hydro_secret_2024

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_string_in_production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# OPC UA / SCADA
OPC_UA_ENDPOINT=opc.tcp://localhost:4840
POLL_INTERVAL_MS=10000
SCADA_SIMULATOR=true

# Email notifications (optional)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=hydropower@example.com

# WhatsApp / SMS (optional)
WHATSAPP_API_URL=
WHATSAPP_API_KEY=
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=

# Logging
LOG_LEVEL=info
LOG_DIR=./logs
